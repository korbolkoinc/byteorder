{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with sanitizers enabled",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "OFF",
        "ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build with LTO",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF",
        "BUILD_EXAMPLES": "OFF",
        "BUILD_BENCHMARKS": "OFF",
        "ENABLE_LTO": "ON"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "description": "Release with debug information",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "description": "Debug build with code coverage instrumentation",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "OFF",
        "BUILD_BENCHMARKS": "OFF",
        "ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "ci-linux-gcc",
      "displayName": "CI Linux GCC",
      "description": "CI configuration for Linux with GCC",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "ON",
        "ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "ci-linux-clang",
      "displayName": "CI Linux Clang",
      "description": "CI configuration for Linux with Clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "ON",
        "ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "ci-windows-msvc",
      "displayName": "CI Windows MSVC",
      "description": "CI configuration for Windows with MSVC",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "ci-macos-clang",
      "displayName": "CI macOS Clang",
      "description": "CI configuration for macOS with AppleClang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_EXAMPLES": "ON",
        "BUILD_BENCHMARKS": "ON",
        "ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "ci-linux-gcc",
      "configurePreset": "ci-linux-gcc"
    },
    {
      "name": "ci-linux-clang",
      "configurePreset": "ci-linux-clang"
    },
    {
      "name": "ci-windows-msvc",
      "configurePreset": "ci-windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "ci-macos-clang",
      "configurePreset": "ci-macos-clang"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      },
      "execution": {
        "noTestsAction": "error",
        "timeout": 120
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "ci-linux-gcc",
      "configurePreset": "ci-linux-gcc",
      "output": {
        "outputOnFailure": true,
        "verbosity": "extra"
      },
      "execution": {
        "noTestsAction": "error",
        "timeout": 120
      }
    },
    {
      "name": "ci-linux-clang",
      "configurePreset": "ci-linux-clang",
      "output": {
        "outputOnFailure": true,
        "verbosity": "extra"
      },
      "execution": {
        "noTestsAction": "error",
        "timeout": 120
      }
    },
    {
      "name": "ci-windows-msvc",
      "configurePreset": "ci-windows-msvc",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "extra"
      },
      "execution": {
        "noTestsAction": "error",
        "timeout": 120
      }
    },
    {
      "name": "ci-macos-clang",
      "configurePreset": "ci-macos-clang",
      "output": {
        "outputOnFailure": true,
        "verbosity": "extra"
      },
      "execution": {
        "noTestsAction": "error",
        "timeout": 120
      }
    }
  ]
}
